# ============================================
# OPC Recruitment System - 环境变量配置
# ============================================

# 服务器配置
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# 前端 URL (用于 CORS)
FRONTEND_URL=http://localhost:3000

# ============================================
# 数据库配置
# ============================================

# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/opc_recruitment?schema=public"

# MongoDB
MONGODB_URI="mongodb://localhost:27017/opc_recruitment"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT & 认证配置
# ============================================

# JWT 密钥 (生产环境请使用强密钥!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ============================================
# AI 服务配置
# ============================================

# QClaw Model Route (LLM 服务)
QCLAW_API_URL=https://api.qclaw.com
QCLAW_API_KEY=your-qclaw-api-key

# OpenAI (备用 LLM)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=

# 向量数据库 (Pinecone)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=opc-recruitment

# OCR 服务 (PaddleOCR)
OCR_SERVICE_URL=http://localhost:9000

# ============================================
# 邮件服务配置
# ============================================

# SMTP 配置 (用于发送邮件)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Recruitment System <noreply@example.com>

# SendGrid (可选)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=OPC Recruitment

# ============================================
# 短信服务配置
# ============================================

# 阿里云短信
ALIYUN_SMS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=你的签名
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# Twilio (可选)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# 微信集成配置
# ============================================

# 微信公众号
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_TOKEN=your-wechat-token
WECHAT_ENCODING_AES_KEY=your-encoding-aes-key

# 微信小程序
WECHAT_MINI_APP_ID=your-mini-app-id
WECHAT_MINI_APP_SECRET=your-mini-app-secret

# ============================================
# 日历服务配置
# ============================================

# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Microsoft Outlook
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
OUTLOOK_REDIRECT_URI=http://localhost:3001/auth/outlook/callback

# ============================================
# 视频会议集成
# ============================================

# Zoom
ZOOM_API_KEY=your-zoom-api-key
ZOOM_API_SECRET=your-zoom-api-secret

# 腾讯会议
TENCENT_MEETING_SDK_ID=your-sdk-id
TENCENT_MEETING_SECRET_ID=your-secret-id
TENCENT_MEETING_SECRET_KEY=your-secret-key

# ============================================
# 文件存储配置
# ============================================

# 本地存储 (开发环境)
UPLOAD_DIR=./uploads

# Cloudflare R2 (生产环境推荐)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=opc-recruitment
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# AWS S3 (可选)
AWS_S3_BUCKET=opc-recruitment
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ============================================
# 监控 & 日志配置
# ============================================

# Sentry (错误追踪)
SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/1234567
SENTRY_ENVIRONMENT=development

# Logtail (日志收集)
LOGTAIL_SOURCE_TOKEN=your-logtail-source-token

# ============================================
# 第三方招聘平台 API
# ============================================

# Boss 直聘
BOSS_ZHIPIN_API_KEY=your-boss-api-key
BOSS_ZHIPIN_COMPANY_ID=your-company-id

# 拉勾网
LAGOU_API_KEY=your-lagou-api-key

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ============================================
# 电子签名配置
# ============================================

# 法大大
FADADA_CLIENT_ID=your-fadada-client-id
FADADA_CLIENT_SECRET=your-fadada-client-secret

# DocuSign
DOCUSIGN_INTEGRATION_KEY=your-integration-key
DOCUSIGN_USER_ID=your-user-id
DOCUSIGN_ACCOUNT_ID=your-account-id
DOCUSIGN_PRIVATE_KEY=your-private-key

# ============================================
# 其他配置
# ============================================

# 速率限制
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 文件上传限制
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt

# CORS 配置 (逗号分隔)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
